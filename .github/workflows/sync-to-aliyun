name: Sync Docker Images to Aliyun Personal Instance

on:
  # 手动触发（推荐测试时使用）
  workflow_dispatch:
  # 定时同步，每天UTC时间18:00（北京时间02:00）
  schedule:
    - cron: '0 18 * * *'

jobs:
  sync-images:
    runs-on: ubuntu-latest
    steps:
      # 步骤1：登录到您的阿里云个人版实例
      - name: Login to Aliyun Personal Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ secrets.ALIYUN_REGISTRY }}
          username: ${{ secrets.ALIYUN_REGISTRY_USER }}
          password: ${{ secrets.ALIYUN_REGISTRY_PASSWORD }}

      # 步骤2：同步 wantcat/trendradar 镜像
      - name: Sync trendradar image
        env:
          ALIYUN_REGISTRY: ${{ secrets.ALIYUN_REGISTRY }}
          NAMESPACE: ${{ secrets.ALIYUN_NAME_SPACE }}
        run: |
          echo "开始同步 trendradar 镜像..."
          
          # 源镜像地址
          SOURCE_IMAGE="wantcat/trendradar:latest"
          # 目标镜像地址
          TARGET_IMAGE="${ALIYUN_REGISTRY}/${NAMESPACE}/trendradar:latest"
          
          # 拉取Docker Hub镜像
          echo "拉取镜像: $SOURCE_IMAGE"
          docker pull $SOURCE_IMAGE
          
          # 重新打标签
          echo "重打标签: $SOURCE_IMAGE -> $TARGET_IMAGE"
          docker tag $SOURCE_IMAGE $TARGET_IMAGE
          
          # 推送到阿里云
          echo "推送镜像: $TARGET_IMAGE"
          docker push $TARGET_IMAGE
          
          echo "✅ trendradar 镜像同步完成"

      # 步骤3：同步 wantcat/trendradar-mcp 镜像
      - name: Sync trendradar-mcp image
        env:
          ALIYUN_REGISTRY: ${{ secrets.ALIYUN_REGISTRY }}
          NAMESPACE: ${{ secrets.ALIYUN_NAME_SPACE }}
        run: |
          echo "开始同步 trendradar-mcp 镜像..."
          
          # 源镜像地址
          SOURCE_IMAGE="wantcat/trendradar-mcp:latest"
          # 目标镜像地址
          TARGET_IMAGE="${ALIYUN_REGISTRY}/${NAMESPACE}/trendradar-mcp:latest"
          
          # 拉取Docker Hub镜像
          echo "拉取镜像: $SOURCE_IMAGE"
          docker pull $SOURCE_IMAGE
          
          # 重新打标签
          echo "重打标签: $SOURCE_IMAGE -> $TARGET_IMAGE"
          docker tag $SOURCE_IMAGE $TARGET_IMAGE
          
          # 推送到阿里云
          echo "推送镜像: $TARGET_IMAGE"
          docker push $TARGET_IMAGE
          
          echo "✅ trendradar-mcp 镜像同步完成"
          
      # 步骤4：验证推送结果
      - name: Verify pushed images
        env:
          ALIYUN_REGISTRY: ${{ secrets.ALIYUN_REGISTRY }}
          NAMESPACE: ${{ secrets.ALIYUN_NAME_SPACE }}
        run: |
          echo "=== 验证推送结果 ==="
          echo "已成功推送到:"
          echo "1. ${ALIYUN_REGISTRY}/${NAMESPACE}/trendradar:latest"
          echo "2. ${ALIYUN_REGISTRY}/${NAMESPACE}/trendradar-mcp:latest"
          echo ""
          echo "您可以在阿里云控制台查看这些镜像:"
          echo "https://cr.console.aliyun.com/repository"
